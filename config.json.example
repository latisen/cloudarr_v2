{
  "bind_address": "0.0.0.0",
  "port": "8282",
  "log_level": "info",

  "debrids": [
    {
      "name": "realdebrid",
      "provider": "realdebrid",
      "api_key": "REPLACE_WITH_YOUR_REAL_DEBRID_API_KEY"
    }
  ],

  "mount": {
    "type": "rclone",
    "mount_path": "/mnt/debrid",
    "rclone": {
      "enabled": true,
      "port": "5572",
      "cache_dir": "/app/rclone-cache",
      "vfs_cache_mode": "full",
      "vfs_cache_max_size": "5G",
      "transfers": 4
    }
  },

  "download_folder": "/mnt/downloads",
  "categories": ["sonarr", "radarr"],
  "default_download_action": "symlink",

  "notifications": {
    "enabled": false
  }
}
